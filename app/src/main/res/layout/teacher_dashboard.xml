<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- 1. The Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavigation"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teacher Dashboard"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/teal_accent"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back, Teacher!"
                android:textSize="15sp"
                android:textColor="@color/text_gray"
                android:layout_marginBottom="24dp"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:alignmentMode="alignMargins"
                android:columnOrderPreserved="false">

                <!-- Total Students Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTotalStudents"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/card_dark"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="150"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/teal_accent"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Students"
                            android:textSize="12sp"
                            android:textColor="@color/text_white"
                            android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Active Classes Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/card_dark">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="4"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#E53935"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Active Classes"
                            android:textSize="12sp"
                            android:textColor="@color/text_white"
                            android:gravity="center"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Teacher Actions"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"/>

            <!-- Teacher Specific Quick Actions -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPostAnnouncement"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Post Announcement"
                android:textAllCaps="false"
                android:textColor="@color/text_white"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/card_dark"
                app:icon="@android:drawable/ic_menu_edit"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@color/teal_accent"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewSubmissions"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="View Submissions"
                android:textAllCaps="false"
                android:textColor="@color/text_white"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/card_dark"
                app:icon="@android:drawable/ic_menu_view"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@color/teal_accent"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGradeBook"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Open Grade Book"
                android:textAllCaps="false"
                android:textColor="@color/text_white"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/card_dark"
                app:icon="@android:drawable/btn_star_big_on"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconTint="@color/teal_accent"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/card_dark"
        app:elevation="16dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/teal_accent"
        app:itemTextColor="@color/text_white"
        app:labelVisibilityMode="labeled"
        app:itemActiveIndicatorColor="@android:color/transparent" />

</RelativeLayout>
