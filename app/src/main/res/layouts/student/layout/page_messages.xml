<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavigation"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Messages"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/teal_accent"
                android:layout_marginBottom="16dp"/>

            <!-- Teacher Announcements Section -->
            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="Direct Messages" 
                android:textColor="@color/teal_accent" 
                android:textStyle="bold" 
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/card_dark">
                <LinearLayout 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:padding="20dp" 
                    android:orientation="vertical">
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="Prof. Reyes" 
                        android:textStyle="bold" 
                        android:textColor="@color/teal_accent"
                        android:textSize="16sp"/>
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="Don't forget the assignment submission by 11:59 PM tonight." 
                        android:textColor="@color/text_white"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Group Chats Section -->
            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content" 
                android:text="Group Chats" 
                android:textColor="@color/teal_accent" 
                android:textStyle="bold" 
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/card_dark">
                <LinearLayout 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:orientation="vertical">
                    
                    <TextView 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:padding="20dp" 
                        android:text="BSIT 3-1 Official GC" 
                        android:textStyle="bold" 
                        android:textColor="@color/text_white"
                        android:drawableStart="@android:drawable/ic_menu_myplaces" 
                        android:drawablePadding="16dp"
                        app:drawableTint="@color/teal_accent"/>
                    
                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:background="@color/bg_dark"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/card_dark"
        app:elevation="16dp"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/teal_accent"
        app:itemTextColor="@color/text_white"
        app:labelVisibilityMode="labeled" />

</RelativeLayout>
